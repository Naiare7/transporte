# URL para que la APP se conecte a la DB dentro de Docker
DATABASE_URL=postgresql://camiones:SLN3@localhost:5432/mydb

# Credenciales unificadas (para que Docker y la App hablen el mismo idioma)
POSTGRES_DB=mydb
POSTGRES_USER=camiones
POSTGRES_PASSWORD=SLN3

# Secretos 
JWT_SECRET_KEY=supersecretkey

# Variables auxiliares (usando el nombre del servicio 'db')
DB_HOST=db
DB_PORT=5432

